---
const navLinks = [
  { label: 'Work',     href: '#work'     },
  { label: 'Method',   href: '#method'   },
  { label: 'Articles', href: '#articles' },
  { label: 'About',    href: '#about'    },
  { label: 'Contact',  href: '#contact'  },
];
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      BH<span class="nav-dot">.</span>
    </a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="#contact" class="nav-cta">Free Audit →</a>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--prussian);
  border-bottom: 2px solid var(--orange);
  padding: 0;
}

.nav-inner {
  display: flex;
  align-items: stretch;
  height: 56px;
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 500;
  color: var(--cream);
  letter-spacing: -0.02em;
  display: flex;
  align-items: center;
  padding-right: 2rem;
  border-right: 1px solid rgba(234,226,183,0.12);
  flex-shrink: 0;
}

.nav-dot { color: var(--orange); }

.nav-links {
  list-style: none;
  display: flex;
  align-items: stretch;
  flex: 1;
  padding-left: 1.5rem;
  gap: 0;
}

.nav-links li {
  display: flex;
  align-items: stretch;
}

.nav-links a {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(234,226,183,0.55);
  display: flex;
  align-items: center;
  padding: 0 1.25rem;
  border-right: 1px solid rgba(234,226,183,0.08);
  transition: color 0.15s, background 0.15s;
}

.nav-links a:hover {
  color: var(--cream);
  background: rgba(247,127,0,0.1);
}

.nav-cta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--prussian);
  background: var(--orange);
  display: flex;
  align-items: center;
  padding: 0 1.75rem;
  margin-left: auto;
  transition: background 0.15s;
  flex-shrink: 0;
}

.nav-cta:hover { background: var(--amber); }

@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-cta   { margin-left: auto; }
}
</style>
