---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <span class="footer-logo">BH<span class="accent">.</span></span>
    <p class="muted">© {year} Bronson Harrington. San José, Costa Rica.</p>
    <div class="footer-links">
      <a href="https://linkedin.com/in/bronsonharrington" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:gnuboss@gmail.com">Email</a>
      <a href="tel:+50661825718">WhatsApp / Call</a>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  padding: 2.5rem 0;
  margin-top: var(--gap);
}

.footer-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.footer-logo {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 500;
}

.footer-inner p {
  font-size: 0.8rem;
  max-width: none;
  margin: 0 auto;
}

.footer-links {
  display: flex;
  gap: 1.5rem;
  margin-left: auto;
}

.footer-links a {
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-muted);
  transition: color 0.2s;
}

.footer-links a:hover { color: var(--accent); }

@media (max-width: 540px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .footer-links { margin-left: 0; }
}
</style>
