<style>
.footer {
  background: var(--prussian);
  color: var(--cream);
  margin-top: var(--gap);
}

.footer-top-rule {
  height: 3px;
  background: var(--orange);
}

.footer-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 3rem;
  padding-top: 3rem;
  padding-bottom: 3rem;
  align-items: start;
}

.footer-logo {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 400;
  display: block;
  margin-bottom: 0.75rem;
}

.footer-tagline {
  font-size: 0.82rem;
  color: rgba(234,226,183,0.5);
  line-height: 1.6;
  max-width: 24ch;
}

.footer-links,
.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding-top: 0.25rem;
}

.footer-links a,
.footer-contact a {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(234,226,183,0.5);
  transition: color 0.15s;
}

.footer-links a:hover,
.footer-contact a:hover { color: var(--orange); }

.footer-bottom {
  border-top: 1px solid rgba(234,226,183,0.1);
  padding: 1.25rem 0 0;
}

.footer-bottom-inner {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  flex-wrap: wrap;
  padding-bottom: 0.75rem;
}

.footer-bottom-inner .label {
  color: rgba(234,226,183,0.3);
}

.footer-creative {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  padding-bottom: 1.5rem;
  border-top: 1px solid rgba(234,226,183,0.06);
  padding-top: 0.75rem;
}

.footer-creative .label {
  color: rgba(234,226,183,0.2);
}

.footer-creative a {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(234,226,183,0.22);
  transition: color 0.15s;
}

.footer-creative a:hover { color: rgba(234,226,183,0.55); }

.footer-sep {
  color: rgba(234,226,183,0.12);
  font-size: 0.7rem;
}

@media (max-width: 640px) {
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom-inner { gap: 1rem; }
}
</style>