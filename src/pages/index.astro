---
import Base from '../layouts/Base.astro';
---

<Base title="Bronson Harrington — Growth Architect & SEO Strategist">

  <!-- ============================================================
       HERO — Full width, propaganda poster energy
  ============================================================ -->
  <section class="hero">
    <div class="hero-bg-text" aria-hidden="true">CREDIBILITY</div>
    <div class="container hero-inner">
      <div class="hero-left">
        <div class="hero-top-bar fade-in">
          <span class="label-orange">— Est. 1999</span>
          <span class="stamp">Due Diligence</span>
        </div>
        <h1 class="hero-headline fade-up delay-1">
          Your web<br/>
          presence<br/>
          is the first<br/>
          thing they<br/>
          <em class="hero-check accent">check.</em>
        </h1>
      </div>
      <div class="hero-right fade-up delay-2">
        <div class="hero-divider-line"></div>
        <p class="hero-sub">
          Most Web3 projects, iGaming operators, and funded startups 
          fail that check — not because the product is weak, but because 
          the digital footprint looks like it was built over a weekend.
        </p>
        <p class="hero-sub" style="margin-top:1rem;color:var(--ink-muted)">
          I build the organic authority infrastructure that changes that.
        </p>
        <div class="hero-actions fade-up delay-3">
          <a href="#contact" class="btn btn-primary">Request Free Audit</a>
          <a href="#method" class="btn">The Method →</a>
        </div>
        <div class="hero-stats fade-up delay-4">
          <div class="hero-stat">
            <span class="hero-stat-num">25<span class="accent">+</span></span>
            <span class="label">Years</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">3<span class="accent">–4</span></span>
            <span class="label">Clients</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-num" style="font-size:1.1rem;letter-spacing:-0.02em">iGaming</span>
            <span class="label">Web3 · Finance</span>
          </div>
        </div>
      </div>
    </div>
    <!-- Diagonal bottom accent -->
    <div class="hero-slash" aria-hidden="true"></div>
  </section>

  <!-- ============================================================
       VERTICALS — Three audiences, surgical copy
  ============================================================ -->
  <section id="work" class="verticals">
    <div class="container">
      <div class="section-header reveal">
        <div class="rule"></div>
        <p class="label">Who I work with</p>
      </div>
      <div class="verticals-grid">

        <div class="vertical reveal">
          <div class="vertical-num label-orange">01</div>
          <h3>Web3 &amp;<br/>Crypto</h3>
          <div class="vertical-rule"></div>
          <p>A project with strong tokenomics and a thin organic footprint reads as a rug pull to anyone who Googles it. Pre-launch credibility architecture changes that before the first investor call.</p>
          <span class="vertical-tag label">Pre-launch · Token listings · DAO legitimacy</span>
        </div>

        <div class="vertical reveal" style="transition-delay:0.12s">
          <div class="vertical-num label-orange">02</div>
          <h3>iGaming<br/>Operators</h3>
          <div class="vertical-rule"></div>
          <p>Entering a new market means passing three layers of scrutiny simultaneously — regulators, affiliates, and players. Your organic presence either opens those doors or closes them before you knock.</p>
          <span class="vertical-tag label">Market entry · Licensing · Affiliate trust</span>
        </div>

        <div class="vertical reveal" style="transition-delay:0.24s">
          <div class="vertical-num label-orange">03</div>
          <h3>Startups &amp;<br/>Founders</h3>
          <div class="vertical-rule"></div>
          <p>Investors run two searches before the meeting: your name, and your company. If neither returns authoritative signals, the meeting already has a headwind. Fix that before the deck goes out.</p>
          <span class="vertical-tag label">Fundraising · Partner trust · Brand authority</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       INTERRUPT BAND — Dark section, strong statement
  ============================================================ -->
  <section class="interrupt section-dark">
    <div class="container interrupt-inner">
      <div class="interrupt-quote reveal">
        <span class="interrupt-mark accent" aria-hidden="true">"</span>
        <h2 class="interrupt-text">
          The informal Google search<br/>
          before every deal is the one<br/>
          most projects aren't ready for<span class="accent">.</span>
        </h2>
      </div>
      <div class="interrupt-right reveal" style="transition-delay:0.2s">
        <p>Most agencies build sites and write content. I build the architecture that makes a brand survive scrutiny — the kind that happens when real money is on the table.</p>
        <a href="#method" class="btn" style="border-color:var(--orange);color:var(--orange);margin-top:2rem;display:inline-block">
          See the method →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       METHOD — Three layers, visual system
  ============================================================ -->
  <section id="method" class="method">
    <div class="container">
<div class="method-header reveal">
        <div class="rule"></div>
        <p class="label">The method</p>
        <h2>Three layers.<br/>One outcome<span class="accent">.</span></h2>
        <p class="method-intro">A 90-day engagement moves through three sequential layers — each one making the next possible. The result is a web presence that compounds over time rather than decaying.</p>
      </div>

      <div class="method-chart reveal">
        <svg width="100%" viewBox="0 0 680 382" role="img" xmlns="http://www.w3.org/2000/svg">
          <title>90-Day Growth Framework</title>
          <desc>A wide-format growth curve showing three stages — Foundation, Authority Build, and Due Diligence Signal — plotted against a 30/60/90-day timeline with an exponential breakout at day 90.</desc>
          <defs>
            <marker id="arrow-up" viewBox="0 0 10 10" refX="5" refY="8" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M1 8L5 2L9 8" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </marker>
            <clipPath id="chart-clip">
              <rect x="80" y="30" width="550" height="270"/>
            </clipPath>
            <linearGradient id="area-fill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#f77f00" stop-opacity="0.2"/>
              <stop offset="55%" stop-color="#fcbf49" stop-opacity="0.08"/>
              <stop offset="100%" stop-color="#003049" stop-opacity="0.02"/>
            </linearGradient>
          </defs>
          <text x="80" y="20" font-family="'DM Mono', monospace" font-size="11" font-weight="500" fill="#003049" opacity="0.85" letter-spacing="1">90-DAY GROWTH FRAMEWORK</text>
          <rect x="80"  y="30" width="183" height="270" fill="#003049" opacity="0.035"/>
          <rect x="263" y="30" width="184" height="270" fill="#fcbf49" opacity="0.05"/>
          <rect x="447" y="30" width="183" height="270" fill="#f77f00" opacity="0.06"/>
          <line x1="80" y1="300" x2="630" y2="300" stroke="#003049" stroke-width="0.5" opacity="0.3"/>
          <line x1="80" y1="210" x2="630" y2="210" stroke="#003049" stroke-width="0.5" opacity="0.1"/>
          <line x1="80" y1="120" x2="630" y2="120" stroke="#003049" stroke-width="0.5" opacity="0.1"/>
          <line x1="80" y1="30"  x2="630" y2="30"  stroke="#003049" stroke-width="0.5" opacity="0.1"/>
          <line x1="263" y1="30" x2="263" y2="300" stroke="#003049" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.2"/>
          <line x1="447" y1="30" x2="447" y2="300" stroke="#003049" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.2"/>
          <path clip-path="url(#chart-clip)" d="M80,298 C100,296 140,292 170,288 C210,282 240,275 263,258 C290,238 310,215 340,188 C365,165 400,145 447,128 C475,118 500,102 530,78 C558,56 590,38 630,30 L630,300 Z" fill="url(#area-fill)"/>
          <path clip-path="url(#chart-clip)" d="M80,298 C100,296 140,292 170,288 C210,282 240,275 263,258 C290,238 310,215 340,188 C365,165 400,145 447,128 C475,118 500,102 530,78 C558,56 590,38 630,30" fill="none" stroke="#003049" stroke-width="2" stroke-linecap="round"/>
          <path d="M630,30 C633,20 636,12 638,4" fill="none" stroke="#f77f00" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round" marker-end="url(#arrow-up)"/>
          <circle cx="80"  cy="298" r="4" fill="#003049" stroke="#eae2b7" stroke-width="2"/>
          <circle cx="263" cy="258" r="5" fill="#003049" stroke="#eae2b7" stroke-width="2"/>
          <circle cx="447" cy="128" r="5" fill="#f77f00" stroke="#eae2b7" stroke-width="2"/>
          <circle cx="630" cy="30"  r="5" fill="#d62828" stroke="#eae2b7" stroke-width="2"/>
          <line x1="80" y1="300" x2="80"  y2="28"  stroke="#003049" stroke-width="1.5" opacity="0.35"/>
          <line x1="80" y1="300" x2="634" y2="300" stroke="#003049" stroke-width="1.5" opacity="0.35"/>
          <line x1="80"  y1="300" x2="80"  y2="308" stroke="#003049" stroke-width="1" opacity="0.4"/>
          <line x1="263" y1="300" x2="263" y2="308" stroke="#003049" stroke-width="1" opacity="0.4"/>
          <line x1="447" y1="300" x2="447" y2="308" stroke="#003049" stroke-width="1" opacity="0.4"/>
          <line x1="630" y1="300" x2="630" y2="308" stroke="#003049" stroke-width="1" opacity="0.4"/>
          <text x="80"  y="322" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" fill="#003049" opacity="0.8">Day 0</text>
          <text x="263" y="322" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" fill="#003049" opacity="0.9">Day 30</text>
          <text x="447" y="322" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" fill="#003049" opacity="0.9">Day 60</text>
          <text x="630" y="322" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" fill="#003049" opacity="0.9">Day 90</text>
          <text x="18" y="168" text-anchor="middle" font-family="'DM Mono', monospace" font-size="10" fill="#003049" opacity="0.7" transform="rotate(-90,18,168)">Organic Authority</text>
          <rect x="88"  y="338" width="118" height="24" rx="12" fill="#003049" opacity="0.07"/>
          <rect x="88"  y="338" width="118" height="24" rx="12" fill="none" stroke="#003049" stroke-width="0.8" opacity="0.2"/>
          <text x="147" y="354" text-anchor="middle" font-family="'DM Mono', monospace" font-size="10" font-weight="500" fill="#003049" opacity="0.75">Foundation</text>
          <rect x="270" y="338" width="130" height="24" rx="12" fill="#fcbf49" opacity="0.15"/>
          <rect x="270" y="338" width="130" height="24" rx="12" fill="none" stroke="#fcbf49" stroke-width="0.8" opacity="0.55"/>
          <text x="335" y="354" text-anchor="middle" font-family="'DM Mono', monospace" font-size="10" font-weight="500" fill="#003049" opacity="0.85">Authority Build</text>
          <rect x="452" y="338" width="148" height="24" rx="12" fill="#f77f00" opacity="0.15"/>
          <rect x="452" y="338" width="148" height="24" rx="12" fill="none" stroke="#f77f00" stroke-width="0.8" opacity="0.55"/>
          <text x="526" y="354" text-anchor="middle" font-family="'DM Mono', monospace" font-size="10" font-weight="500" fill="#003049" opacity="0.85">DD Signal</text>
          <text x="644" y="22" text-anchor="start" font-family="'DM Mono', monospace" font-size="10" fill="#d62828" opacity="0.9">↑ Off chart</text>
          <text x="171" y="52" text-anchor="middle" font-family="'DM Mono', monospace" font-size="9" fill="#003049" opacity="0.3" letter-spacing="1">01</text>
          <text x="355" y="52" text-anchor="middle" font-family="'DM Mono', monospace" font-size="9" fill="#003049" opacity="0.3" letter-spacing="1">02</text>
          <text x="538" y="52" text-anchor="middle" font-family="'DM Mono', monospace" font-size="9" fill="#003049" opacity="0.3" letter-spacing="1">03</text>
        </svg>
      </div>

      <div class="layers">

        <div class="layer reveal">
          <div class="layer-num">
            <span class="label-orange">01</span>
            <div class="layer-connector-line"></div>
          </div>
          <div class="layer-content">
            <h3>Foundation</h3>
            <p class="label" style="margin:0.5rem 0 1rem">Design · Technical SEO · Site Architecture</p>
            <p>Does this brand look and function like a legitimate operation? Brand design, Core Web Vitals, crawl architecture, schema, and technical health — the baseline every other layer depends on.</p>
          </div>
          <div class="layer-tag">
            <span class="layer-tag-inner">Layer 01</span>
          </div>
        </div>

        <div class="layer reveal" style="transition-delay:0.15s">
          <div class="layer-num">
            <span class="label-orange">02</span>
            <div class="layer-connector-line"></div>
          </div>
          <div class="layer-content">
            <h3>Authority Build</h3>
            <p class="label" style="margin:0.5rem 0 1rem">Topical Authority · Content Architecture · Entity SEO</p>
            <p>Can this brand be found, cited, and trusted by search engines — and the humans behind them? Organic growth built on topical depth, not volume. Authority that reads as expertise, not optimization.</p>
          </div>
          <div class="layer-tag">
            <span class="layer-tag-inner">Layer 02</span>
          </div>
        </div>

        <div class="layer layer-hero reveal" style="transition-delay:0.3s">
          <div class="layer-num">
            <span style="color:var(--orange);font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase">03</span>
          </div>
          <div class="layer-content">
            <h3>Due Diligence Signal<span class="accent">.</span></h3>
            <p class="label" style="margin:0.5rem 0 1rem;color:var(--orange)">Investor-grade presence · Regulatory footprint · Partner trust</p>
            <p>Does this brand survive a sceptical third-party Google search? The output of everything below it — a web presence that passes the informal due diligence that happens before every deal, deposit, and partnership.</p>
          </div>
          <div class="layer-tag">
            <span class="layer-tag-inner" style="background:var(--orange);color:var(--cream);border-color:var(--orange)">The Output</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       ABOUT — Asymmetric layout, editorial feel
  ============================================================ -->
  <section id="about" class="about section-dark">
    <div class="container about-inner">
      <div class="about-left reveal">
        <div class="rule"></div>
        <p class="label" style="color:rgba(234,226,183,0.4);margin-bottom:1.5rem">About</p>
        <h2>25 years in<br/>rooms where<br/>trust is the<br/>product<span class="accent">.</span></h2>
        <div class="about-markers">
          <div class="about-marker">
            <span class="about-marker-num accent">25+</span>
            <span class="label" style="color:rgba(234,226,183,0.4)">Years organic growth</span>
          </div>
          <div class="about-marker">
            <span class="about-marker-num accent">3–4</span>
            <span class="label" style="color:rgba(234,226,183,0.4)">Clients at a time</span>
          </div>
        </div>
      </div>
      <div class="about-right reveal" style="transition-delay:0.2s">
        <p>I've spent the better part of two and a half decades building organic growth systems for finance brands, iGaming operators, and digital businesses where credibility isn't a marketing concern — it's an operational one.</p>
        <p style="margin-top:1.25rem">That background means I understand what's actually at stake when a Web3 project goes to market with a thin footprint, or an iGaming operator enters a regulated jurisdiction with no organic authority signals. I've seen what it costs.</p>
        <p style="margin-top:1.25rem">I work with a small number of clients at a time — typically three or four — because the work demands the kind of attention you can't distribute across a full agency roster.</p>
        <div class="about-verticals">
          <span class="label-orange">iGaming</span>
          <span class="about-dot">·</span>
          <span class="label-orange">Finance</span>
          <span class="about-dot">·</span>
          <span class="label-orange">Web3</span>
          <span class="about-dot">·</span>
          <span class="label-orange">Startups</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA — Assessor framing, scarcity signal
  ============================================================ -->
  <section id="contact" class="contact">
    <div class="container contact-inner">
      <div class="contact-left reveal">
        <div class="rule"></div>
        <p class="label">Free audit</p>
        <h2>Before the<br/>meeting, know<br/>where you<br/>stand<span class="accent">.</span></h2>
      </div>
      <div class="contact-right reveal" style="transition-delay:0.2s">
        <p>I offer a free due diligence scan of your web presence — the same assessment a cautious investor or regulator would run informally before engaging.</p>
        <p style="margin-top:1rem;color:var(--ink-muted)">No pitch. No proposal. Just an honest read of what your digital footprint is currently signalling.</p>

        <div class="contact-form" style="margin-top:2.5rem">
          <form action="https://formsubmit.co/gnuboss@gmail.com" method="POST">
            <input type="hidden" name="_subject" value="Free Audit Request — Bronson Harrington">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">

            <div class="form-row">
              <div class="form-field">
                <label class="label" for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required>
              </div>
              <div class="form-field">
                <label class="label" for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required>
              </div>
            </div>

            <div class="form-field">
              <label class="label" for="vertical">Your vertical</label>
              <select id="vertical" name="vertical" required>
                <option value="">Select...</option>
                <option>Web3 / Crypto</option>
                <option>iGaming / Casino</option>
                <option>Startup / Founder</option>
                <option>Finance / Fintech</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-field">
              <label class="label" for="message">Tell me about your project</label>
              <textarea id="message" name="message" rows="4" placeholder="URL, context, what's at stake..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Send Request →</button>
          </form>
        </div>

        <p class="label" style="margin-top:1.5rem;color:var(--ink-muted)">
          Or reach out directly:
          <a href="mailto:gnuboss@gmail.com" style="color:var(--orange)">gnuboss@gmail.com</a>
          &nbsp;·&nbsp;
          <a href="https://wa.me/50661825718" style="color:var(--orange)" target="_blank" rel="noopener">WhatsApp</a>
        </p>
      </div>
    </div>
  </section>

</Base>

<style>
/* ---- HERO ---- */
.hero {
  position: relative;
  overflow: hidden;
  padding: clamp(4rem, 10vw, 7rem) 0 clamp(3rem, 8vw, 5rem);
  border-bottom: 2px solid var(--ink);
}

.hero-bg-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-display);
  font-size: clamp(8rem, 22vw, 22rem);
  font-weight: 600;
  color: var(--prussian);
  opacity: 0.04;
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: -0.04em;
  user-select: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 6vw, 5rem);
  align-items: start;
}

.hero-top-bar {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.hero-headline {
  line-height: 1.0;
}

.hero-check {
  font-style: italic;
}

.hero-right {
  padding-top: 1rem;
}

.hero-divider-line {
  width: 100%;
  height: 1px;
  background: var(--border-strong);
  margin-bottom: 1.75rem;
}

.hero-sub {
  font-size: clamp(0.95rem, 1.3vw, 1.05rem);
  color: var(--ink-soft);
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 2.25rem;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: 0 1.75rem 0 0;
}

.hero-stat:first-child { padding-left: 0; }

.hero-stat-num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 300;
  line-height: 1;
  letter-spacing: -0.03em;
}

.hero-stat-divider {
  width: 1px;
  height: 36px;
  background: var(--border-strong);
  margin-right: 1.75rem;
  flex-shrink: 0;
}

/* ---- VERTICALS ---- */
.section-header {
  margin-bottom: 3rem;
}

.verticals-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--border-strong);
}

.vertical {
  padding: 2.5rem 2rem;
  border-right: 1px solid var(--border-strong);
  position: relative;
  transition: background 0.2s;
}

.vertical:last-child { border-right: none; }
.vertical:hover { background: rgba(0,48,73,0.04); }

.vertical-num {
  margin-bottom: 1.25rem;
}

.vertical h3 {
  margin-bottom: 1rem;
  line-height: 1.15;
}

.vertical-rule {
  width: 32px;
  height: 2px;
  background: var(--orange);
  margin-bottom: 1rem;
}

.vertical p {
  font-size: 0.9rem;
  color: var(--ink-soft);
  margin-bottom: 1.5rem;
  line-height: 1.72;
}

.vertical-tag { display: block; }

@media (max-width: 700px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-bg-text { font-size: 5rem; opacity: 0.03; }
  .hero-right { padding-top: 0; }
  .hero-divider-line { display: none; }
  .verticals-grid { grid-template-columns: 1fr; }
  .vertical { border-right: none; border-bottom: 1px solid var(--border-strong); }
  .vertical:last-child { border-bottom: none; }
}

/* ---- INTERRUPT ---- */
.interrupt {
  padding: clamp(3rem, 8vw, 6rem) 0;
}

.interrupt-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: clamp(2rem, 6vw, 5rem);
  align-items: center;
}

.interrupt-mark {
  font-family: var(--font-display);
  font-size: 6rem;
  line-height: 0.5;
  display: block;
  margin-bottom: 1.5rem;
  opacity: 0.6;
}

.interrupt-text {
  font-size: clamp(1.6rem, 3vw, 2.6rem);
  line-height: 1.15;
  color: var(--cream);
}

.interrupt-right p {
  color: rgba(234,226,183,0.65);
  font-size: 0.95rem;
}

@media (max-width: 700px) {
  .interrupt-inner { grid-template-columns: 1fr; }
}

/* ---- METHOD ---- */
.method-header {
  max-width: 500px;
  margin-bottom: 3.5rem;
}

.method-header h2 { margin-top: 0.75rem; }

.method-intro {
  font-size: 0.95rem;
  color: var(--ink-soft);
  margin-top: 1rem;
  max-width: 56ch;
}

.method-chart {
