---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  month: 'long',
  year: 'numeric',
}).format(article.data.date);
---

<Base
  title={`${article.data.title} — Bronson Harrington`}
  description={article.data.summary}
  ogImage="https://gnuboss.github.io/og-image.svg"
>

  <article class="article-page">
    <div class="container">

      <!-- Article header -->
      <header class="article-header">
        <a href="/#articles" class="article-back">← Back</a>
        <div class="article-meta">
          <span class="label">{formattedDate}</span>
        </div>
        <h1 class="article-title">{article.data.title}</h1>
        <p class="article-summary">{article.data.summary}</p>
        <div class="article-rule"></div>
      </header>

      <!-- Article body -->
      <div class="prose">
        <Content />
      </div>

      <!-- Article footer -->
      <footer class="article-footer">
        <div class="article-footer-rule"></div>
        <div class="article-footer-inner">
          <a href="/#articles" class="btn">← Back to articles</a>
          <a href="/#contact" class="btn btn-primary">Request a free audit →</a>
        </div>
      </footer>

    </div>
  </article>

</Base>

<style>
.article-page {
  padding: clamp(3rem, 8vw, 5rem) 0 var(--gap);
}

.article-back {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-muted);
  display: inline-block;
  margin-bottom: 2.5rem;
  transition: color 0.15s;
}

.article-back:hover { color: var(--orange); }

.article-meta {
  margin-bottom: 1rem;
}

.article-title {
  font-size: clamp(2rem, 5vw, 3.8rem);
  line-height: 1.08;
  max-width: 18ch;
  margin-bottom: 1.25rem;
}

.article-summary {
  font-size: 1.05rem;
  color: var(--ink-soft);
  font-style: italic;
  max-width: 58ch;
  line-height: 1.65;
  margin-bottom: 2rem;
}

.article-rule {
  width: 48px;
  height: 3px;
  background: var(--orange);
  margin-bottom: 3rem;
}

/* ---- PROSE STYLES ---- */
.prose {
  max-width: 68ch;
  font-size: 1.02rem;
  line-height: 1.82;
  color: var(--ink-soft);
}

.prose h2 {
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 400;
  color: var(--ink);
  margin: 2.5rem 0 1rem;
  line-height: 1.2;
}

.prose h3 {
  font-size: 1.15rem;
  font-weight: 500;
  color: var(--ink);
  margin: 2rem 0 0.75rem;
}

.prose p {
  margin-bottom: 1.4rem;
  max-width: none;
}

.prose strong {
  font-weight: 500;
  color: var(--ink);
}

.prose em {
  font-style: italic;
}

.prose ul,
.prose ol {
  padding-left: 1.5rem;
  margin-bottom: 1.4rem;
}

.prose li {
  margin-bottom: 0.5rem;
  line-height: 1.75;
}

.prose blockquote {
  border-left: 3px solid var(--orange);
  padding-left: 1.5rem;
  margin: 2rem 0;
  font-style: italic;
  color: var(--ink-soft);
}

.prose hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2.5rem 0;
}

.prose a {
  color: var(--orange);
  text-decoration: underline;
  text-decoration-color: rgba(247,127,0,0.35);
  text-underline-offset: 3px;
  transition: text-decoration-color 0.15s;
}

.prose a:hover {
  text-decoration-color: var(--orange);
}

.prose code {
  font-family: var(--font-mono);
  font-size: 0.88em;
  background: rgba(0,48,73,0.06);
  padding: 0.15em 0.4em;
  border-radius: 3px;
}

/* ---- ARTICLE FOOTER ---- */
.article-footer {
  margin-top: 4rem;
  max-width: 68ch;
}

.article-footer-rule {
  width: 100%;
  height: 1px;
  background: var(--border);
  margin-bottom: 2rem;
}

.article-footer-inner {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

@media (max-width: 600px) {
  .article-footer-inner { flex-direction: column; }
  .article-footer-inner .btn { text-align: center; }
}
</style>
